# syntax=docker/dockerfile:1.7
ARG NODE_IMAGE=node:22-alpine
FROM ${NODE_IMAGE} AS base
WORKDIR /app

FROM base AS builder
# 新增 sqlite 编译/运行依赖，解决 better-sqlite3 编译 & disk I/O error
RUN apk --no-cache upgrade && apk --no-cache add \
    python3 make g++ linux-headers \
    sqlite-dev musl-dev sqlite-libs git

# 国内镜像加速 better-sqlite3 预编译包，避免下载失败
RUN echo "better_sqlite3_binary_host=https://registry.npmmirror.com/-/binary/better-sqlite3" >> /root/.npmrc

COPY package.json ./
RUN --mount=type=cache,target=/root/.npm \
  npm install

# 关键：强制完整编译 better-sqlite3 在构建阶段完成
RUN npm rebuild better-sqlite3

COPY . ./
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM ${NODE_IMAGE} AS runner
WORKDIR /app

LABEL org.opencontainers.image.title="9router"

ENV NODE_ENV=production
ENV PORT=20128
ENV HOSTNAME=0.0.0.0
ENV NEXT_TELEMETRY_DISABLED=1
ENV DATA_DIR=/app/data

# --------------------------核心修复：完整拷贝所有 node_modules，不再缺 sql.js wasm 文件--------------------------
# 原逻辑只拷少量依赖导致 sql-wasm.wasm 丢失，此处全量复制构建层 node_modules
COPY --from=builder /app/node_modules ./node_modules

# 原有静态/打包文件拷贝保留不变
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/custom-server.js ./custom-server.js
COPY --from=builder /app/open-sse ./open-sse
COPY --from=builder /app/src/mitm ./src/mitm

# 下面这两段单独拷贝 node-forge/next 可以删掉了，全量 node_modules 已包含，保留也无妨
# COPY --from=builder /app/node_modules/node-forge ./node_modules/node-forge
# COPY --from=builder /app/node_modules/next ./node_modules/next

# 运行层安装 sqlite 运行时库，解决 disk I/O error
RUN apk --no-cache upgrade && apk --no-cache add sqlite-libs su-exec

# 目录创建、权限归属 node 用户
RUN mkdir -p /app/data && chown -R node:node /app && \
  mkdir -p /app/data-home && chown node:node /app/data-home && \
  ln -sf /app/data-home /root/.9router 2>/dev/null || true

# 入口脚本：启动前自动修正挂载卷权限
RUN printf '#!/bin/sh\nchown -R node:node /app/data /app/data-home 2>/dev/null\nexec su-exec node "$@"\n' > /entrypoint.sh && \
  chmod +x /entrypoint.sh

EXPOSE 20128

ENTRYPOINT ["/entrypoint.sh"]
CMD ["node", "custom-server.js"]