# syntax=docker/dockerfile:1.7
ARG NODE_IMAGE=node:22-alpine
FROM ${NODE_IMAGE} AS base
WORKDIR /app

# 预装git + 国内npm镜像
RUN apk --no-cache add git && \
    npm config set registry https://registry.npmmirror.com && \
    npm config set fetch-timeout 120000 && \
    echo "better_sqlite3_binary_host=https://registry.npmmirror.com/-/binary/better-sqlite3" >> /root/.npmrc

FROM base AS builder
# 完整sqlite编译依赖
RUN apk --no-cache add \
    python3 make g++ linux-headers \
    sqlite-dev musl-dev sqlite-libs

COPY package.json ./
# 移除 --mount=cache 缓存挂载，不再占用构建磁盘
RUN npm install

# 预编译better-sqlite3
RUN npm rebuild better-sqlite3

COPY . ./
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM ${NODE_IMAGE} AS runner
WORKDIR /app

LABEL org.opencontainers.image.title="9router"
LABEL org.opencontainers.image.description="AI Gateway 9router full sqlite support"

ENV NODE_ENV=production
ENV PORT=20128
ENV HOSTNAME=0.0.0.0
ENV NEXT_TELEMETRY_DISABLED=1
ENV DATA_DIR=/app/data

# 全量复制node_modules，修复sql-wasm.wasm缺失
COPY --from=builder /app/node_modules ./node_modules

COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/custom-server.js ./custom-server.js
COPY --from=builder /app/open-sse ./open-sse
COPY --from=builder /app/src/mitm ./src/mitm

# 运行时依赖
RUN apk --no-cache add su-exec sqlite-libs

# 初始化数据目录
RUN mkdir -p /app/data /app/data-home \
    && ln -sf /app/data-home /root/.9router 2>/dev/null || true \
    && chown -R node:node /app

# 权限修复入口脚本
RUN printf '#!/bin/sh\nset -e\nchown -R node:node /app/data /app/data-home 2>/dev/null || true\nexec su-exec node "$@"\n' > /entrypoint.sh \
    && chmod +x /entrypoint.sh

USER node
EXPOSE 20128
ENTRYPOINT ["/entrypoint.sh"]
CMD ["node", "custom-server.js"]